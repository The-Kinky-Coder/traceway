{
    "name": "traceway/devtesting-symfony",
    "description": "Symfony test application for Traceway via OpenTelemetry",
    "type": "project",
    "repositories": [
        {
            "type": "path",
            "url": "/Users/dusanstanojevic/Documents/workspace/opentelemetry-symfony-bundle"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/framework-bundle": "^7.0",
        "symfony/routing": "^7.0",
        "symfony/dotenv": "^7.0",
        "symfony/yaml": "^7.0",
        "open-telemetry/sdk": "^1.0",
        "open-telemetry/exporter-otlp": "^1.0",
        "php-http/guzzle7-adapter": "^1.0",
        "traceway/opentelemetry-symfony": "@dev",
        "symfony/string": "^7.0",
        "symfony/messenger": "^8.0",
        "symfony/doctrine-messenger": "^8.0",
        "doctrine/doctrine-bundle": "^3.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "tbachert/spi": true
        }
    },
    "scripts": {
        "start": "php -S localhost:8080 public/index.php"
    }
}
